# AiToEarn API key — lấy tại https://aitoearn.ai → Settings → API Key
AITOEARN_API_KEY=ak_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AiToEarn endpoint — quốc tế hoặc TQ
# Quốc tế:    https://aitoearn.ai/api/unified/mcp
# Trung Quốc: https://aitoearn.cn/api/unified/mcp
AITOEARN_MCP_URL=https://aitoearn.ai/api/unified/mcp

# ima2-gen URL — nơi `ima2 serve` đang chạy
# Mặc định ima2 ghi port ra ~/.ima2/server.json — wizard sẽ auto-discover.
# Để trống cũng được.
IMA2_SERVER=

# CDN provider để upload ảnh local → URL public:
#   catbox  — free, không cần key (mặc định)
#   imgbb   — free, cần API key tại https://api.imgbb.com/
STORAGE_PROVIDER=catbox

# Chỉ cần nếu STORAGE_PROVIDER=imgbb
IMGBB_API_KEY=
